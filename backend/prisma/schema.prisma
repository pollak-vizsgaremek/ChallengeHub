generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model categories {
  uuid                               String    @id @db.VarChar(36)
  type                               String    @db.VarChar(128)
  name                               String    @db.VarChar(255)
  created_at                         DateTime  @default(now()) @db.DateTime(0)
  created_by                         String    @db.VarChar(36)
  updated_at                         DateTime? @db.DateTime(0)
  updated_by                         String?   @db.VarChar(36)
  users_categories_created_byTousers users     @relation("categories_created_byTousers", fields: [created_by], references: [uuid], onUpdate: Restrict, map: "categories_ibfk_1")
  users_categories_updated_byTousers users?    @relation("categories_updated_byTousers", fields: [updated_by], references: [uuid], onDelete: Restrict, onUpdate: Restrict, map: "categories_ibfk_2")
  tasks                              tasks[]

  @@index([created_by, updated_by], map: "created_by")
  @@index([updated_by], map: "categories_ibfk_2")
}

model reviews {
  uuid       String   @id @db.VarChar(36)
  rating     Int
  comment    String   @db.Text
  task_id    String   @db.VarChar(36)
  user_id    String   @db.VarChar(36)
  created_at DateTime @default(now()) @db.DateTime(0)
  users      users    @relation(fields: [user_id], references: [uuid], onUpdate: Restrict, map: "reviews_ibfk_1")
  tasks      tasks    @relation(fields: [task_id], references: [uuid], onUpdate: Restrict, map: "reviews_ibfk_2")

  @@index([task_id, user_id], map: "task_id")
  @@index([user_id], map: "reviews_ibfk_1")
}

model tasks {
  uuid                          String       @id @default(uuid()) @db.VarChar(36)
  name                          String       @db.VarChar(128)
  description                   String       @db.Text
  xp                            Int
  coin                          Int
  categories_id                 String       @db.VarChar(36)
  created_at                    DateTime     @default(now()) @db.DateTime(0)
  created_by                    String       @db.VarChar(36)
  updated_at                    DateTime?    @db.DateTime(0)
  updated_by                    String?      @db.VarChar(36)
  reviews                       reviews[]
  users_tasks_created_byTousers users        @relation("tasks_created_byTousers", fields: [created_by], references: [uuid], onUpdate: Restrict, map: "tasks_ibfk_1")
  users_tasks_updated_byTousers users?       @relation("tasks_updated_byTousers", fields: [updated_by], references: [uuid], onDelete: Restrict, onUpdate: Restrict, map: "tasks_ibfk_2")
  categories                    categories   @relation(fields: [categories_id], references: [uuid], onUpdate: Restrict, map: "tasks_ibfk_3")
  user_tasks                    user_tasks[]

  @@index([categories_id], map: "categories_id")
  @@index([created_by, updated_by], map: "created_by")
  @@index([updated_by], map: "tasks_ibfk_2")
}

model user_interests {
  uuid        String   @id @default(uuid()) @db.VarChar(36)
  user_id     String   @db.VarChar(36)
  category_id String   @db.VarChar(36)
  created_at  DateTime @default(now()) @db.DateTime(0)

  @@unique([user_id, category_id])
  @@index([category_id])
  @@index([user_id])
}

model user_tasks {
  uuid         String    @id @default(uuid()) @db.VarChar(36)
  status       Int       @default(0) @db.TinyInt
  task_id      String    @db.VarChar(36)
  user_id      String    @db.VarChar(36)
  created_at   DateTime  @default(now()) @db.DateTime(0)
  completed_at DateTime? @db.DateTime(0)
  users        users     @relation(fields: [user_id], references: [uuid], onUpdate: Restrict, map: "user_tasks_ibfk_1")
  tasks        tasks     @relation(fields: [task_id], references: [uuid], onUpdate: Restrict, map: "user_tasks_ibfk_2")

  @@index([task_id, user_id], map: "task_id")
  @@index([user_id], map: "user_tasks_ibfk_1")
}

model users {
  uuid                                    String                 @id @default(uuid()) @db.VarChar(36)
  username                                String                 @db.VarChar(128)
  email                                   String                 @unique(map: "email") @db.VarChar(255)
  password                                String                 @db.VarChar(255)
  xp                                      Int
  coin                                    Int
  admin                                   Int
  registered_at                           DateTime               @default(now()) @db.DateTime(0)
  onboarding_completed                    Boolean                @default(false)
  activity_level                          String?                @db.VarChar(20)
  current_streak                          Int                    @default(0)
  last_completed_at                       DateTime?              @db.DateTime(0)
  longest_streak                          Int                    @default(0)
  active_border_id                        String?                @db.VarChar(36)
  active_name_color_id                    String?                @db.VarChar(36)
  categories_categories_created_byTousers categories[]           @relation("categories_created_byTousers")
  categories_categories_updated_byTousers categories[]           @relation("categories_updated_byTousers")
  reviews                                 reviews[]
  tasks_tasks_created_byTousers           tasks[]                @relation("tasks_created_byTousers")
  tasks_tasks_updated_byTousers           tasks[]                @relation("tasks_updated_byTousers")
  tickets                                 tickets[]
  user_endpoint_access                    user_endpoint_access[]
  user_shop_items                         user_shop_items[]
  user_tasks                              user_tasks[]
}

model shop_items {
  uuid            String            @id @default(uuid()) @db.VarChar(36)
  name            String            @db.VarChar(128)
  description     String            @db.Text
  price           Int
  category        String            @db.VarChar(50)
  created_at      DateTime          @default(now()) @db.DateTime(0)
  value           String?           @db.VarChar(255)
  user_shop_items user_shop_items[]
}

model user_shop_items {
  uuid         String     @id @default(uuid()) @db.VarChar(36)
  user_id      String     @db.VarChar(36)
  shop_item_id String     @db.VarChar(36)
  purchased_at DateTime   @default(now()) @db.DateTime(0)
  users        users      @relation(fields: [user_id], references: [uuid], onUpdate: Restrict, map: "user_shop_items_ibfk_1")
  shop_items   shop_items @relation(fields: [shop_item_id], references: [uuid], onUpdate: Restrict, map: "user_shop_items_ibfk_2")

  @@unique([user_id, shop_item_id], map: "user_shop_uniq")
  @@index([shop_item_id], map: "shop_item_id")
  @@index([user_id], map: "user_id")
}

model user_endpoint_access {
  uuid     String @id @db.VarChar(36)
  endpoint String @db.VarChar(100)
  methods  String @db.Text
  user_id  String @db.VarChar(36)
  users    users  @relation(fields: [user_id], references: [uuid], onUpdate: Restrict, map: "user_endpoint_access_ibfk_1")

  @@index([user_id], map: "user_id")
}

model tickets {
  uuid        String   @id @default(uuid()) @db.VarChar(36)
  user_id     String   @db.VarChar(36)
  type        String   @db.VarChar(50)
  title       String   @db.VarChar(255)
  description String   @db.Text
  priority    String   @db.VarChar(20)
  status      String   @default("open") @db.VarChar(20)
  created_at  DateTime @default(now()) @db.DateTime(0)
  users       users    @relation(fields: [user_id], references: [uuid], onUpdate: Restrict, map: "fk_tickets_users")

  @@index([user_id], map: "idx_tickets_user_id")
}
